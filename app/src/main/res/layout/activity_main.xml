<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/num0"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="83dp"
        android:layout_height="82dp"
        android:layout_marginBottom="40dp"
        android:scaleX="1"
        android:text="0"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/resultview"
        android:layout_width="411dp"
        android:layout_height="138dp"
        android:layout_marginTop="16dp"
        android:textSize="48sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.529"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/num9"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="83dp"
        android:layout_height="82dp"
        android:layout_marginStart="32dp"
        android:layout_marginBottom="20dp"
        android:scaleX="1"
        android:text="9"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/num6"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/plusbtn"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="83dp"
        android:layout_height="82dp"
        android:layout_marginStart="32dp"
        android:layout_marginBottom="60dp"
        android:scaleX="1"
        android:text="+"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/num9"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/minusbtn"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="83dp"
        android:layout_height="82dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="60dp"
        android:scaleX="1"
        android:text="-"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/num7"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/equalbtn"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="83dp"
        android:layout_height="82dp"
        android:layout_marginBottom="56dp"
        android:scaleX="1"
        android:text="="
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/num8"
        app:layout_constraintEnd_toStartOf="@+id/minusbtn"
        app:layout_constraintStart_toEndOf="@+id/plusbtn" />

    <Button
        android:id="@+id/num6"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="83dp"
        android:layout_height="82dp"
        android:layout_marginStart="32dp"
        android:layout_marginBottom="20dp"
        android:scaleX="1"
        android:text="6"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/num3"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/num3"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="83dp"
        android:layout_height="82dp"
        android:layout_marginStart="32dp"
        android:layout_marginBottom="140dp"
        android:scaleX="1"
        android:text="3"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/num2"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="83dp"
        android:layout_height="82dp"
        android:layout_marginBottom="20dp"
        android:scaleX="1"
        android:text="2"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/num0"
        app:layout_constraintEnd_toStartOf="@+id/num1"
        app:layout_constraintStart_toEndOf="@+id/num3" />

    <Button
        android:id="@+id/num1"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="83dp"
        android:layout_height="82dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="140dp"
        android:scaleX="1"
        android:text="1"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/num5"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="83dp"
        android:layout_height="82dp"
        android:layout_marginBottom="20dp"
        android:scaleX="1"
        android:text="5"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/num2"
        app:layout_constraintEnd_toStartOf="@+id/num4"
        app:layout_constraintStart_toEndOf="@+id/num6" />

    <Button
        android:id="@+id/num4"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="83dp"
        android:layout_height="82dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="20dp"
        android:scaleX="1"
        android:text="4"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/num1"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/num7"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="83dp"
        android:layout_height="82dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="20dp"
        android:scaleX="1"
        android:text="7"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/num4"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/num8"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="83dp"
        android:layout_height="82dp"
        android:layout_marginBottom="20dp"
        android:scaleX="1"
        android:text="8"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/num5"
        app:layout_constraintEnd_toStartOf="@+id/num7"
        app:layout_constraintStart_toEndOf="@+id/num9" />

</androidx.constraintlayout.widget.ConstraintLayout>